{
    "schemaVersion": 1,
    "id": "devorcification",
    "version": "${version}",
    "name": "Devorcification: The Loop",
    "description": "A psychological horror mod that divorces you from reality",
    "authors": [
        "Aofsnorth"
    ],
    "contact": {
        "homepage": "https://github.com/Aofsnorth/Devorcification-The-Loop",
        "sources": "https://github.com/Aofsnorth/Devorcification-The-Loop"
    },
    "license": "MIT",
    "icon": "assets/devorcification/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.devorcification.Devorcification"
        ],
        "client": [
            "com.devorcification.client.DevorcificationClient"
        ],
        "server": [
            "com.devorcification.server.DevorcificationServer"
        ]
    },
    "mixins": [
        "devorcification.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.15.0",
        "minecraft": "~1.20.1",
        "java": ">=17",
        "fabric-api": "*"
    },
    "suggests": {
        "midnightlib": "*"
    }
}
